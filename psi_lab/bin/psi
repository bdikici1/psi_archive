#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$HOME/psi_archive"
PSI_LAB="$BASE_DIR/psi_lab"
MINT_JOBS="$PSI_LAB/nfts/mint_jobs"

cmd="${1:-}"
glyph_id="${2:-}"

if [[ -z "$cmd" ]]; then
  echo "ψ usage: psi <register|status|mintprep> GLYPH_ID"
  exit 1;
fi

case "$cmd" in
  register)
    if [[ -z "$glyph_id" ]]; then
      echo "Usage: psi register GLYPH_ID"
      exit 1
    fi
    job_dir="$MINT_JOBS/$glyph_id"
    mkdir -p "$job_dir"
    state="$job_dir/state.json"

    if [[ ! -f "$state" ]]; then
      cat > "$state" <<EOF
{
  "id": "$glyph_id",
  "status": "registered",
  "stage": "meta_ready",
  "created_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
}
EOF
      echo "[OK] Registered $glyph_id"
    else
      echo "[OK] $glyph_id already registered (state.json exists)"
    fi
    ;;

  status)
    if [[ -z "$glyph_id" ]]; then
      echo "Usage: psi status GLYPH_ID"
      exit 1
    fi
    job_dir="$MINT_JOBS/$glyph_id"
    state="$job_dir/state.json"

    echo "------ STATUS FOR $glyph_id ------"
    if [[ -f "$state" ]]; then
      cat "$state"
    else
      echo "No state found at: $state"
    fi
    ;;

  mintprep)
    echo "psi commands:"
    echo "  psi register HYPERCORE_010-B"
    echo "  psi status HYPERCORE_010-B"
    echo "  (ileri aşama: psi prepare-metadata / psi prepare-ipfs ...)"
    ;;

  *)
    echo "Unknown command: $cmd"
    exit 1
    ;;
esac
